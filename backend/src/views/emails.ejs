<%- include('./layout') %>

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-2">
  <div>
    <h1 class="page-title">Emails</h1>
    <p class="page-subtitle">Payment notification emails from Gmail (<%= pagination.total %> total)</p>
  </div>
  <button class="btn btn-primary" onclick="fetchEmails()" id="fetchBtn">
    <i class="bi bi-cloud-download-fill me-2"></i>Fetch Gmail
  </button>
</div>

<!-- Filters -->
<div class="table-card mb-3">
  <form method="GET" action="/emails" class="p-3">
    <div class="row g-2 align-items-end">
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">Status</label>
        <select name="status" class="form-select form-select-sm">
          <option value="">All</option>
          <option value="PENDING" <%= filters.status === 'PENDING' ? 'selected' : '' %>>Pending</option>
          <option value="VERIFIED" <%= filters.status === 'VERIFIED' ? 'selected' : '' %>>Verified</option>
          <option value="UNVERIFIED" <%= filters.status === 'UNVERIFIED' ? 'selected' : '' %>>Unverified</option>
        </select>
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">UTR</label>
        <input type="text" name="utr" class="form-control form-control-sm" placeholder="Search UTR..." value="<%= filters.utr || '' %>">
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">Sender</label>
        <input type="text" name="sender" class="form-control form-control-sm" placeholder="Email or name..." value="<%= filters.sender || '' %>">
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">Amount</label>
        <input type="number" name="amount" class="form-control form-control-sm" placeholder="Amount (INR)" value="<%= filters.amount || '' %>">
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">From</label>
        <input type="date" name="from" class="form-control form-control-sm" value="<%= filters.from || '' %>">
      </div>
      <div class="col-6 col-md-2">
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
            <i class="bi bi-search"></i> Filter
          </button>
          <a href="/emails" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-x"></i>
          </a>
        </div>
      </div>
    </div>
  </form>
</div>

<!-- Table -->
<div class="table-card">
  <div class="table-responsive">
    <table class="table mb-0">
      <thead>
        <tr>
          <th>Sender</th>
          <th>Subject</th>
          <th>UTR</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Received</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (emails.length === 0) { %>
        <tr>
          <td colspan="7" class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            No emails found. <a href="#" onclick="fetchEmails()">Fetch from Gmail</a>
          </td>
        </tr>
        <% } %>
        <% emails.forEach(email => { %>
        <tr>
          <td>
            <div class="fw-semibold"><%= email.sender || '—' %></div>
            <div class="text-muted small"><%= email.senderEmail || '' %></div>
          </td>
          <td>
            <div class="text-truncate" style="max-width:200px;" title="<%= email.subject %>">
              <%= email.subject || '—' %>
            </div>
          </td>
          <td>
            <% if (email.utr) { %>
              <code class="text-info"><%= email.utr %></code>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td>
            <% if (email.amount) { %>
              <span class="fw-semibold text-success">₹<%= email.amount.toLocaleString() %></span>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td>
            <% if (email.status === 'VERIFIED') { %>
              <span class="status-badge-verified"><i class="bi bi-check-circle-fill"></i>Verified</span>
            <% } else if (email.status === 'UNVERIFIED') { %>
              <span class="status-badge-unverified"><i class="bi bi-x-circle-fill"></i>Unverified</span>
            <% } else { %>
              <span class="status-badge-pending"><i class="bi bi-clock-fill"></i>Pending</span>
            <% } %>
          </td>
          <td class="text-muted small"><%= new Date(email.receivedAt).toLocaleString() %></td>
          <td>
            <div class="d-flex gap-1">
              <button class="btn btn-sm btn-outline-secondary" onclick="viewBody('<%= email._id %>')" title="View body">
                <i class="bi bi-eye-fill"></i>
              </button>
              <button class="btn btn-sm btn-danger" onclick="deleteEmail('<%= email._id %>', this)" title="Delete">
                <i class="bi bi-trash-fill"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (pagination.totalPages > 1) { %>
  <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top" style="border-color:var(--border-color)!important;">
    <span class="text-muted small">
      Showing <%= ((pagination.page-1)*pagination.limit)+1 %>–<%= Math.min(pagination.page*pagination.limit, pagination.total) %> of <%= pagination.total %>
    </span>
    <nav>
      <ul class="pagination pagination-sm mb-0 gap-1">
        <% for(let p = 1; p <= pagination.totalPages; p++) { %>
          <li class="page-item <%= p === pagination.page ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= p %>&status=<%= filters.status||'' %>&utr=<%= filters.utr||'' %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  </div>
  <% } %>
</div>

<!-- Email Body Modal -->
<div class="modal fade" id="emailBodyModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content" style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:16px;">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title">Email Details</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="emailBodyContent">
        <div class="text-center py-4"><span class="spinner-border text-primary"></span></div>
      </div>
    </div>
  </div>
</div>

<script>
async function fetchEmails() {
  const btn = document.getElementById('fetchBtn');
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Fetching...';
  btn.disabled = true;
  try {
    const res = await fetch('/api/emails/fetch', { method: 'POST' });
    const data = await res.json();
    showToast(`Fetched ${data.data?.fetched || 0} emails, saved ${data.data?.saved || 0} new`, 'success');
    setTimeout(() => location.reload(), 1000);
  } catch(e) {
    showToast('Fetch failed: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-cloud-download-fill me-2"></i>Fetch Gmail';
  }
}

async function deleteEmail(id, btn) {
  if (!confirm('Delete this email record?')) return;
  btn.disabled = true;
  try {
    const res = await fetch('/api/email/' + id, { method: 'DELETE' });
    if (res.ok) {
      btn.closest('tr').style.opacity = '0';
      setTimeout(() => btn.closest('tr').remove(), 300);
      showToast('Email deleted', 'success');
    }
  } catch(e) {
    showToast('Delete failed', 'error');
    btn.disabled = false;
  }
}

async function viewBody(id) {
  const modal = new bootstrap.Modal(document.getElementById('emailBodyModal'));
  document.getElementById('emailBodyContent').innerHTML = '<div class="text-center py-4"><span class="spinner-border text-primary"></span></div>';
  modal.show();
  try {
    const res = await fetch('/api/emails?limit=1');
    // Show placeholder — in production you'd add GET /api/email/:id endpoint
    document.getElementById('emailBodyContent').innerHTML = `<p class="text-muted">Email ID: <code>${id}</code></p><p>Use the GET /api/emails endpoint to view full body.</p>`;
  } catch(e) {
    document.getElementById('emailBodyContent').innerHTML = '<p class="text-danger">Failed to load</p>';
  }
}
</script>

<%- include('./partials/layout-end') %>
