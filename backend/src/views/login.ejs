<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="PayVerify Admin Login — WhatsApp Payment Verification System">
  <title>Login — PayVerify</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #6366f1;
      --bg-base: #0f1117;
      --bg-card: #1e2235;
      --border-color: rgba(255,255,255,0.08);
    }
    * { box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-base);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      position: relative;
      overflow: hidden;
    }
    /* Animated gradient orbs */
    body::before {
      content: '';
      position: fixed;
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, transparent 70%);
      top: -200px; left: -200px;
      pointer-events: none; animation: orb1 8s ease-in-out infinite;
    }
    body::after {
      content: '';
      position: fixed;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(139,92,246,0.12) 0%, transparent 70%);
      bottom: -150px; right: -150px;
      pointer-events: none; animation: orb2 10s ease-in-out infinite;
    }
    @keyframes orb1 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(60px, 40px); } }
    @keyframes orb2 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-40px, -50px); } }

    .login-card {
      background: rgba(30,34,53,0.9);
      backdrop-filter: blur(30px);
      border: 1px solid var(--border-color);
      border-radius: 24px;
      padding: 3rem 2.5rem;
      width: 100%; max-width: 420px;
      position: relative; z-index: 1;
      box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    }
    .login-logo {
      width: 64px; height: 64px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      border-radius: 20px;
      display: flex; align-items: center; justify-content: center;
      font-size: 2rem; color: white;
      margin: 0 auto 1.5rem;
      box-shadow: 0 8px 25px rgba(99,102,241,0.4);
    }
    .login-title {
      font-size: 1.6rem; font-weight: 800;
      text-align: center; margin-bottom: 4px;
      background: linear-gradient(135deg, #e2e8f0, #a5b4fc);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .login-subtitle {
      text-align: center; color: #6b7280;
      font-size: 0.875rem; margin-bottom: 2rem;
    }
    .btn-google {
      display: flex; align-items: center; justify-content: center; gap: 12px;
      width: 100%; padding: 14px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      border: none; border-radius: 14px;
      color: white; font-size: 0.95rem; font-weight: 600;
      text-decoration: none; transition: all 0.25s;
      box-shadow: 0 4px 20px rgba(99,102,241,0.35);
    }
    .btn-google:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(99,102,241,0.5);
      color: white;
    }
    .btn-google:active { transform: translateY(0); }
    .google-icon {
      width: 22px; height: 22px;
      background: white; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .google-icon svg { width: 14px; height: 14px; }
    .divider {
      display: flex; align-items: center; gap: 12px;
      color: #4b5563; font-size: 0.8rem; margin: 1.5rem 0;
    }
    .divider::before, .divider::after {
      content: ''; flex: 1; height: 1px;
      background: var(--border-color);
    }
    .feature-list { list-style: none; padding: 0; margin: 0; }
    .feature-list li {
      display: flex; align-items: center; gap: 10px;
      font-size: 0.82rem; color: #6b7280;
      padding: 4px 0;
    }
    .feature-list li i { color: #6366f1; font-size: 0.9rem; }
    .error-alert {
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 12px; padding: 12px 16px;
      color: #fca5a5; font-size: 0.85rem;
      margin-bottom: 1.5rem;
      display: flex; align-items: center; gap: 10px;
    }
    .security-note {
      text-align: center; font-size: 0.75rem; color: #4b5563;
      margin-top: 1.5rem;
    }
    .security-note i { color: #6366f1; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="login-logo">
      <i class="bi bi-shield-check-fill"></i>
    </div>

    <h1 class="login-title">PayVerify</h1>
    <p class="login-subtitle">WhatsApp Payment Verification System</p>

    <% if (error) { %>
    <div class="error-alert">
      <i class="bi bi-exclamation-circle-fill"></i>
      <%= error %>
    </div>
    <% } %>

    <a href="/auth/google" class="btn-google" id="loginBtn">
      <div class="google-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
      </div>
      Sign in with Google
    </a>

    <div class="divider">protected access</div>

    <ul class="feature-list">
      <li><i class="bi bi-whatsapp"></i> Real-time WhatsApp payment monitoring</li>
      <li><i class="bi bi-envelope-check-fill"></i> Automated Gmail UTR extraction</li>
      <li><i class="bi bi-cpu-fill"></i> AI-powered payment verification</li>
      <li><i class="bi bi-graph-up-arrow"></i> Analytics & reporting dashboard</li>
    </ul>

    <p class="security-note">
      <i class="bi bi-lock-fill me-1"></i>
      Secured by Google OAuth 2.0 — your credentials are never stored
    </p>
  </div>

  <script>
    document.getElementById('loginBtn').addEventListener('click', function() {
      this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Redirecting...';
    });
  </script>
</body>
</html>
