<%- include('./layout') %>

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-2">
  <div>
    <h1 class="page-title">Verifications</h1>
    <p class="page-subtitle">Match WhatsApp payment screenshots with Gmail emails (<%= pagination.total %> records)</p>
  </div>
  <div class="d-flex gap-2">
    <% if (unmatched > 0) { %>
    <span class="status-badge-pending"><i class="bi bi-exclamation-triangle-fill"></i> <%= unmatched %> unmatched</span>
    <% } %>
    <button class="btn btn-primary" onclick="runMatching()" id="matchBtn">
      <i class="bi bi-cpu-fill me-2"></i>Run Matching
    </button>
  </div>
</div>

<!-- Filters -->
<div class="table-card mb-3">
  <form method="GET" action="/verification" class="p-3">
    <div class="row g-2 align-items-end">
      <div class="col-6 col-md-3">
        <label class="form-label small text-muted mb-1">Status</label>
        <select name="status" class="form-select form-select-sm">
          <option value="">All</option>
          <option value="PENDING" <%= filters.status === 'PENDING' ? 'selected' : '' %>>Pending</option>
          <option value="VERIFIED" <%= filters.status === 'VERIFIED' ? 'selected' : '' %>>Verified</option>
          <option value="UNVERIFIED" <%= filters.status === 'UNVERIFIED' ? 'selected' : '' %>>Unverified</option>
        </select>
      </div>
      <div class="col-6 col-md-3">
        <label class="form-label small text-muted mb-1">From Date</label>
        <input type="date" name="from" class="form-control form-control-sm" value="<%= filters.from || '' %>">
      </div>
      <div class="col-6 col-md-3">
        <label class="form-label small text-muted mb-1">To Date</label>
        <input type="date" name="to" class="form-control form-control-sm" value="<%= filters.to || '' %>">
      </div>
      <div class="col-6 col-md-3">
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
            <i class="bi bi-search"></i> Filter
          </button>
          <a href="/verification" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x"></i></a>
        </div>
      </div>
    </div>
  </form>
</div>

<!-- Verification Table -->
<div class="table-card">
  <div class="table-responsive">
    <table class="table mb-0">
      <thead>
        <tr>
          <th>Screenshot</th>
          <th>WhatsApp Sender</th>
          <th>WA UTR</th>
          <th>Email Sender</th>
          <th>Email UTR</th>
          <th>Amount</th>
          <th>Confidence</th>
          <th>Status</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (verifications.length === 0) { %>
        <tr>
          <td colspan="10" class="text-center py-5 text-muted">
            <i class="bi bi-patch-question fs-1 d-block mb-2"></i>No verification records yet.
            <br><small>WhatsApp images with UTR will appear here automatically.</small>
          </td>
        </tr>
        <% } %>
        <% verifications.forEach(v => { %>
        <tr id="row-<%= v._id %>">
          <td>
            <% if (v.whatsappId?.imageUrl || v.whatsappId?.imagePath) { %>
              <img src="<%= v.whatsappId.imageUrl || '' %>" class="img-thumbnail-sm"
                   onclick="viewImage(this.src)" alt="Screenshot"
                   onerror="this.style.display='none'">
            <% } else { %>
              <div class="img-thumbnail-sm d-flex align-items-center justify-content-center text-muted" style="background:var(--bg-surface);">
                <i class="bi bi-image"></i>
              </div>
            <% } %>
          </td>
          <td>
            <div class="fw-semibold"><%= v.whatsappId?.senderName || '—' %></div>
            <div class="text-muted small"><%= v.whatsappId?.groupName || '' %></div>
          </td>
          <td>
            <% if (v.whatsappId?.utr) { %>
              <code class="text-info small"><%= v.whatsappId.utr %></code>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td>
            <div class="fw-semibold small"><%= v.emailId?.sender || '—' %></div>
            <div class="text-muted" style="font-size:0.7rem;max-width:120px;" class="text-truncate"><%= v.emailId?.subject?.substring(0,30) || '' %></div>
          </td>
          <td>
            <% if (v.emailId?.utr) { %>
              <code class="text-info small"><%= v.emailId.utr %></code>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td>
            <% const amt = v.emailId?.amount || v.whatsappId?.amount; %>
            <% if (amt) { %>
              <span class="fw-semibold text-success">₹<%= amt.toLocaleString() %></span>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td>
            <div class="d-flex align-items-center gap-2">
              <span class="confidence-bar">
                <span class="confidence-fill" style="width:<%= v.confidence %>%;background:<%= v.confidence>=70?'#10b981':v.confidence>=40?'#f59e0b':'#ef4444' %>;"></span>
              </span>
              <small><%= v.confidence %>%</small>
            </div>
            <div class="text-muted" style="font-size:0.68rem;"><%= (v.matchedFields||[]).join(', ') %></div>
          </td>
          <td>
            <% if (v.status === 'VERIFIED') { %>
              <span class="status-badge-verified"><i class="bi bi-check-circle-fill"></i>Verified</span>
            <% } else if (v.status === 'UNVERIFIED') { %>
              <span class="status-badge-unverified"><i class="bi bi-x-circle-fill"></i>Unverified</span>
            <% } else { %>
              <span class="status-badge-pending"><i class="bi bi-clock-fill"></i>Pending</span>
            <% } %>
            <% if (v.verifiedBy) { %>
              <div class="text-muted" style="font-size:0.68rem;">by <%= v.verifiedBy %></div>
            <% } %>
          </td>
          <td class="text-muted small"><%= new Date(v.createdAt).toLocaleDateString() %></td>
          <td>
            <div class="d-flex gap-1 flex-wrap">
              <a href="/verification/<%= v._id %>" class="btn btn-sm btn-outline-secondary" title="Details">
                <i class="bi bi-eye-fill"></i>
              </a>
              <% if (v.status !== 'VERIFIED') { %>
              <button class="btn btn-sm btn-success" onclick="manualVerify('<%= v._id %>')" title="Verify">
                <i class="bi bi-check-lg"></i>
              </button>
              <% } %>
              <% if (v.status === 'VERIFIED') { %>
              <button class="btn btn-sm btn-warning" onclick="manualUnverify('<%= v._id %>')" title="Unverify">
                <i class="bi bi-x-lg"></i>
              </button>
              <% } %>
              <button class="btn btn-sm btn-danger" onclick="deleteVerification('<%= v._id %>')" title="Delete">
                <i class="bi bi-trash-fill"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (pagination.totalPages > 1) { %>
  <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top" style="border-color:var(--border-color)!important;">
    <span class="text-muted small">Showing <%= ((pagination.page-1)*pagination.limit)+1 %>–<%= Math.min(pagination.page*pagination.limit, pagination.total) %> of <%= pagination.total %></span>
    <nav>
      <ul class="pagination pagination-sm mb-0 gap-1">
        <% for(let p = 1; p <= pagination.totalPages; p++) { %>
          <li class="page-item <%= p === pagination.page ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= p %>&status=<%= filters.status||'' %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  </div>
  <% } %>
</div>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title">Payment Screenshot</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-3">
        <img id="imageModalSrc" src="" class="img-fluid rounded" alt="" style="max-height:70vh;">
      </div>
    </div>
  </div>
</div>

<script>
function viewImage(src) {
  document.getElementById('imageModalSrc').src = src;
  new bootstrap.Modal(document.getElementById('imageModal')).show();
}

async function runMatching() {
  const btn = document.getElementById('matchBtn');
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Matching...';
  btn.disabled = true;
  try {
    const res = await fetch('/api/verification/match', { method: 'POST' });
    showToast('Matching engine triggered. Refreshing...', 'success');
    setTimeout(() => location.reload(), 1500);
  } catch(e) {
    showToast('Failed: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-cpu-fill me-2"></i>Run Matching';
  }
}

async function manualVerify(id) {
  try {
    const res = await fetch('/api/verify/' + id, { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
    const data = await res.json();
    if (res.ok) {
      showToast('Transaction verified!', 'success');
      setTimeout(() => location.reload(), 800);
    } else {
      showToast(data.message || 'Verify failed', 'error');
    }
  } catch(e) { showToast('Error: ' + e.message, 'error'); }
}

async function manualUnverify(id) {
  if (!confirm('Mark this transaction as unverified?')) return;
  try {
    const res = await fetch('/api/unverify/' + id, { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
    if (res.ok) {
      showToast('Transaction unverified', 'warning');
      setTimeout(() => location.reload(), 800);
    }
  } catch(e) { showToast('Error: ' + e.message, 'error'); }
}

async function deleteVerification(id) {
  if (!confirm('Delete this verification record?')) return;
  try {
    const res = await fetch('/api/verification/' + id, { method: 'DELETE' });
    if (res.ok) {
      document.getElementById('row-' + id)?.remove();
      showToast('Deleted', 'success');
    }
  } catch(e) { showToast('Delete failed', 'error'); }
}
</script>

<%- include('./partials/layout-end') %>
