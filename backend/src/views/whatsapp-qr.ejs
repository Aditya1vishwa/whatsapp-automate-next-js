<%- include('./layout') %>

<style>
  .qr-card { background:var(--bg-card); border:1px solid var(--border-color); border-radius:20px; padding:2.5rem; max-width:440px; margin:2rem auto; text-align:center; }
  .qr-img { border-radius:16px; padding:1rem; background:white; display:inline-block; }
</style>

<div class="qr-card">
      <% if (clientReady) { %>
        <i class="bi bi-whatsapp" style="font-size:4rem;color:#25D366;"></i>
        <h2 class="mt-3 fw-bold">WhatsApp Connected!</h2>
        <p class="text-muted">Your WhatsApp account is authenticated and listening for payment messages.</p>
        <a href="/whatsapp" class="btn btn-success mt-2">View Messages</a>
      <% } else if (hasQR && qrImageUrl) { %>
        <h2 class="fw-bold mb-3">Scan QR Code</h2>
        <p class="text-muted mb-4">Open WhatsApp on your phone → Linked Devices → Link a Device → Scan this code</p>
        <div class="qr-img mb-4">
          <img src="<%= qrImageUrl %>" alt="WhatsApp QR Code" style="width:280px;height:280px;">
        </div>
        <p class="text-muted small">QR refreshes every 20 seconds. <a href="" onclick="location.reload()">Refresh page</a> if expired.</p>
        <div class="mt-3">
          <div class="spinner-border spinner-border-sm text-success me-2"></div>
          <span class="text-muted small">Waiting for scan...</span>
        </div>
        <script>setTimeout(()=>location.reload(), 20000);</script>
      <% } else { %>
        <i class="bi bi-wifi-off" style="font-size:4rem;color:#6b7280;"></i>
        <h2 class="mt-3 fw-bold">WhatsApp Initializing</h2>
        <p class="text-muted">The WhatsApp client is starting up. Please check the server console for the QR code, or refresh this page in a moment.</p>
        <button class="btn btn-primary mt-2" onclick="location.reload()">
          <i class="bi bi-arrow-clockwise me-2"></i>Refresh
        </button>
        <script>setTimeout(()=>location.reload(), 5000);</script>
      <% } %>
</div>

<%- include('./partials/layout-end') %>
