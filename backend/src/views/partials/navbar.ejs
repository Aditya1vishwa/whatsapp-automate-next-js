<nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNavbar">
  <div class="container-fluid px-4">
    <!-- Brand -->
    <a class="navbar-brand d-flex align-items-center gap-2" href="/dashboard">
      <div class="brand-icon">
        <i class="bi bi-shield-check-fill"></i>
      </div>
      <span class="brand-name">PayVerify</span>
    </a>

    <!-- Right side -->
    <div class="d-flex align-items-center gap-3 ms-auto">
      <!-- WhatsApp status indicator -->
      <div class="status-badge" id="waStatusBadge">
        <span class="status-dot" id="waStatusDot"></span>
        <span class="status-text d-none d-md-inline" id="waStatusText">WhatsApp</span>
      </div>

      <!-- Notifications -->
      <button class="btn btn-icon position-relative" id="notifBtn" title="Notifications">
        <i class="bi bi-bell-fill"></i>
        <span class="notif-badge" id="notifBadge">0</span>
      </button>

      <!-- User avatar dropdown -->
      <div class="dropdown">
        <button class="btn btn-icon d-flex align-items-center gap-2" data-bs-toggle="dropdown" id="userDropdownBtn">
          <% if (user && user.picture) { %>
            <img src="<%= user.picture %>" class="user-avatar" alt="<%= user.name %>">
          <% } else { %>
            <div class="user-avatar-placeholder">
              <i class="bi bi-person-fill"></i>
            </div>
          <% } %>
          <span class="d-none d-md-inline user-name"><%= user ? user.name : 'Admin' %></span>
          <i class="bi bi-chevron-down fs-xs"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
          <li class="px-3 py-2 border-bottom">
            <div class="fw-semibold text-body"><%= user ? user.name : 'Admin' %></div>
            <div class="text-muted small"><%= user ? user.email : '' %></div>
          </li>
          <li><a class="dropdown-item" href="/settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
          <li><a class="dropdown-item" href="/admin/whatsapp-qr"><i class="bi bi-qr-code me-2"></i>WhatsApp QR</a></li>
          <li><hr class="dropdown-divider"></li>
          <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
        </ul>
      </div>
    </div>
  </div>
</nav>

<script>
// Poll WhatsApp status every 30 seconds
async function checkWAStatus() {
  try {
    const res = await fetch('/api/whatsapp/status');
    const data = await res.json();
    const dot = document.getElementById('waStatusDot');
    const text = document.getElementById('waStatusText');
    const badge = document.getElementById('notifBadge');
    if (data.data?.ready) {
      dot.className = 'status-dot online';
      text.textContent = 'WhatsApp';
    } else if (data.data?.hasQR) {
      dot.className = 'status-dot pending';
      text.textContent = 'Scan QR';
    } else {
      dot.className = 'status-dot offline';
      text.textContent = 'Offline';
    }
  } catch(e) {}
}
checkWAStatus();
setInterval(checkWAStatus, 30000);
</script>
