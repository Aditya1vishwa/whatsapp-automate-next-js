<%- include('./layout') %>

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-2">
  <div>
    <h1 class="page-title">WhatsApp Messages</h1>
    <p class="page-subtitle">Payment screenshots received from WhatsApp groups (<%= pagination.total %> total)</p>
  </div>
  <div class="d-flex gap-2">
    <% if (!clientReady) { %>
    <a href="/admin/whatsapp-qr" class="btn btn-warning">
      <i class="bi bi-qr-code me-2"></i>Scan QR Code
    </a>
    <% } else { %>
    <span class="status-badge-verified"><i class="bi bi-whatsapp"></i> WhatsApp Connected</span>
    <% } %>
  </div>
</div>

<!-- Filters -->
<div class="table-card mb-3">
  <form method="GET" action="/whatsapp" class="p-3">
    <div class="row g-2 align-items-end">
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">Status</label>
        <select name="status" class="form-select form-select-sm">
          <option value="">All</option>
          <option value="PENDING" <%= filters.status === 'PENDING' ? 'selected' : '' %>>Pending</option>
          <option value="VERIFIED" <%= filters.status === 'VERIFIED' ? 'selected' : '' %>>Verified</option>
          <option value="UNVERIFIED" <%= filters.status === 'UNVERIFIED' ? 'selected' : '' %>>Unverified</option>
        </select>
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">UTR</label>
        <input type="text" name="utr" class="form-control form-control-sm" placeholder="Search UTR..." value="<%= filters.utr || '' %>">
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">Group</label>
        <input type="text" name="group" class="form-control form-control-sm" placeholder="Group name..." value="<%= filters.group || '' %>">
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">Sender</label>
        <input type="text" name="sender" class="form-control form-control-sm" placeholder="Name..." value="<%= filters.sender || '' %>">
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">Phone</label>
        <input type="text" name="phone" class="form-control form-control-sm" placeholder="Phone..." value="<%= filters.phone || '' %>">
      </div>
      <div class="col-6 col-md-2">
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
            <i class="bi bi-search"></i> Filter
          </button>
          <a href="/whatsapp" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x"></i></a>
        </div>
      </div>
    </div>
  </form>
</div>

<!-- Table -->
<div class="table-card">
  <div class="table-responsive">
    <table class="table mb-0">
      <thead>
        <tr>
          <th>Image</th>
          <th>Sender</th>
          <th>Group</th>
          <th>UTR</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Received</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (messages.length === 0) { %>
        <tr>
          <td colspan="8" class="text-center py-5 text-muted">
            <i class="bi bi-chat-dots fs-1 d-block mb-2"></i>
            No WhatsApp messages yet. Make sure WhatsApp is connected.
          </td>
        </tr>
        <% } %>
        <% messages.forEach(msg => { %>
        <tr>
          <td>
            <% if (msg.imageUrl || msg.imagePath) { %>
              <img src="<%= msg.imageUrl || '/uploads/whatsapp/' + require('path').basename(msg.imagePath||'') %>"
                   class="img-thumbnail-sm"
                   onclick="viewImage(this.src)"
                   alt="Payment screenshot"
                   onerror="this.style.display='none'">
            <% } else { %>
              <div class="img-thumbnail-sm d-flex align-items-center justify-content-center text-muted" style="background:var(--bg-surface);">
                <i class="bi bi-image"></i>
              </div>
            <% } %>
          </td>
          <td>
            <div class="fw-semibold"><%= msg.senderName || '—' %></div>
            <div class="text-muted small"><%= msg.senderNumber || '' %></div>
          </td>
          <td class="text-muted small"><%= msg.groupName || 'Direct' %></td>
          <td>
            <% if (msg.utr) { %>
              <code class="text-info"><%= msg.utr %></code>
            <% } else { %>
              <span class="text-muted small">Not found</span>
            <% } %>
          </td>
          <td>
            <% if (msg.amount) { %>
              <span class="fw-semibold text-success">₹<%= msg.amount.toLocaleString() %></span>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td>
            <% if (msg.status === 'VERIFIED') { %>
              <span class="status-badge-verified"><i class="bi bi-check-circle-fill"></i>Verified</span>
            <% } else if (msg.status === 'UNVERIFIED') { %>
              <span class="status-badge-unverified"><i class="bi bi-x-circle-fill"></i>Unverified</span>
            <% } else { %>
              <span class="status-badge-pending"><i class="bi bi-clock-fill"></i>Pending</span>
            <% } %>
          </td>
          <td class="text-muted small"><%= new Date(msg.createdAt).toLocaleString() %></td>
          <td>
            <div class="d-flex gap-1">
              <% if (msg.ocrText) { %>
              <button class="btn btn-sm btn-outline-secondary" onclick="viewOCR('<%= msg._id %>', `<%= (msg.ocrText || '').substring(0,500).replace(/`/g, '') %>`)" title="View OCR">
                <i class="bi bi-file-text-fill"></i>
              </button>
              <% } %>
              <button class="btn btn-sm btn-danger" onclick="deleteWA('<%= msg._id %>', this)" title="Delete">
                <i class="bi bi-trash-fill"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (pagination.totalPages > 1) { %>
  <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top" style="border-color:var(--border-color)!important;">
    <span class="text-muted small">Showing <%= ((pagination.page-1)*pagination.limit)+1 %>–<%= Math.min(pagination.page*pagination.limit, pagination.total) %> of <%= pagination.total %></span>
    <nav>
      <ul class="pagination pagination-sm mb-0 gap-1">
        <% for(let p = 1; p <= pagination.totalPages; p++) { %>
          <li class="page-item <%= p === pagination.page ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= p %>&status=<%= filters.status||'' %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  </div>
  <% } %>
</div>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title">Payment Screenshot</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-3">
        <img id="imageModalSrc" src="" class="img-fluid rounded" alt="Payment screenshot" style="max-height:70vh;">
      </div>
    </div>
  </div>
</div>

<!-- OCR Modal -->
<div class="modal fade" id="ocrModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content" style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:16px;">
      <div class="modal-header border-0">
        <h5 class="modal-title"><i class="bi bi-file-text-fill me-2 text-info"></i>OCR Text</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <pre id="ocrText" class="p-3 rounded" style="background:var(--bg-base);color:#e2e8f0;font-size:0.8rem;white-space:pre-wrap;max-height:400px;overflow-y:auto;"></pre>
      </div>
    </div>
  </div>
</div>

<script>
function viewImage(src) {
  document.getElementById('imageModalSrc').src = src;
  new bootstrap.Modal(document.getElementById('imageModal')).show();
}
function viewOCR(id, text) {
  document.getElementById('ocrText').textContent = text || 'No OCR text available';
  new bootstrap.Modal(document.getElementById('ocrModal')).show();
}
async function deleteWA(id, btn) {
  if (!confirm('Delete this WhatsApp record?')) return;
  btn.disabled = true;
  try {
    const res = await fetch('/api/whatsapp/' + id, { method: 'DELETE' });
    if (res.ok) {
      btn.closest('tr').style.opacity = '0';
      setTimeout(() => btn.closest('tr').remove(), 300);
      showToast('Record deleted', 'success');
    }
  } catch(e) {
    showToast('Delete failed', 'error');
    btn.disabled = false;
  }
}
</script>

<%- include('./partials/layout-end') %>
