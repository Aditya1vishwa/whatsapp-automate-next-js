<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="PayVerify — Dashboard">
  <title><%= title %> — PayVerify</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --sidebar-width:260px; --navbar-height:60px;
      --primary:#6366f1; --primary-dark:#4f46e5; --primary-soft:rgba(99,102,241,0.12);
      --success:#10b981; --success-soft:rgba(16,185,129,0.12);
      --warning:#f59e0b; --warning-soft:rgba(245,158,11,0.12);
      --danger:#ef4444; --danger-soft:rgba(239,68,68,0.12);
      --bg-base:#0f1117; --bg-surface:#1a1d2e; --bg-card:#1e2235; --bg-card-hover:#252840;
      --border-color:rgba(255,255,255,0.07); --text-muted-custom:#7c849c;
      --sidebar-bg:#13162a; --glass-bg:rgba(30,34,53,0.85);
    }
    *{box-sizing:border-box;} body{font-family:'Inter',sans-serif;background:var(--bg-base);color:#e2e8f0;margin:0;overflow-x:hidden;}
    ::-webkit-scrollbar{width:6px;height:6px;} ::-webkit-scrollbar-track{background:transparent;} ::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.15);border-radius:3px;}
    #mainNavbar{height:var(--navbar-height);background:var(--glass-bg);backdrop-filter:blur(20px);border-bottom:1px solid var(--border-color);z-index:1050;}
    .brand-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--primary),#8b5cf6);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:white;}
    .brand-name{font-weight:700;font-size:1.15rem;letter-spacing:-0.5px;}
    .btn-icon{background:transparent;border:1px solid var(--border-color);color:#c4c9df;border-radius:10px;padding:6px 10px;font-size:1rem;transition:all 0.2s;}
    .btn-icon:hover{background:var(--primary-soft);border-color:var(--primary);color:white;}
    .user-avatar{width:32px;height:32px;border-radius:50%;object-fit:cover;}
    .user-avatar-placeholder{width:32px;height:32px;border-radius:50%;background:var(--primary-soft);color:var(--primary);display:flex;align-items:center;justify-content:center;}
    .notif-badge{position:absolute;top:4px;right:4px;background:var(--danger);color:white;font-size:0.65rem;font-weight:700;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;}
    .status-badge{display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:20px;background:var(--bg-card);border:1px solid var(--border-color);font-size:0.78rem;font-weight:500;}
    .status-dot{width:8px;height:8px;border-radius:50%;background:#6b7280;transition:background 0.3s;}
    .status-dot.online{background:var(--success);box-shadow:0 0 6px var(--success);animation:pulse 2s infinite;}
    .status-dot.pending{background:var(--warning);} .status-dot.offline{background:var(--danger);}
    @keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.5;}}
    .sidebar{position:fixed;top:var(--navbar-height);left:0;bottom:0;width:var(--sidebar-width);background:var(--sidebar-bg);border-right:1px solid var(--border-color);z-index:1040;overflow-y:auto;transition:transform 0.3s ease;}
    .sidebar-inner{display:flex;flex-direction:column;height:100%;padding:1rem 0;}
    .sidebar-nav{flex:1;padding:0 0.75rem;}
    .nav-section-label{font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted-custom);padding:1.2rem 0.75rem 0.4rem;}
    .sidebar-nav .nav-link{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;color:#9ca3af;font-size:0.875rem;font-weight:500;transition:all 0.2s;margin-bottom:2px;text-decoration:none;}
    .sidebar-nav .nav-link:hover{background:var(--primary-soft);color:white;}
    .sidebar-nav .nav-link.active{background:linear-gradient(135deg,var(--primary-soft),rgba(139,92,246,0.1));color:white;border:1px solid rgba(99,102,241,0.25);}
    .nav-icon{font-size:1.05rem;min-width:20px;text-align:center;}
    .nav-badge{margin-left:auto;background:var(--primary);color:white;font-size:0.68rem;font-weight:700;padding:2px 7px;border-radius:10px;display:none;}
    .sidebar-footer{padding:0.75rem;border-top:1px solid var(--border-color);margin-top:auto;}
    .sidebar-user{display:flex;align-items:center;gap:10px;}
    .sidebar-avatar{width:36px;height:36px;border-radius:50%;object-fit:cover;}
    .sidebar-avatar-placeholder{width:36px;height:36px;border-radius:50%;background:var(--primary-soft);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:1.1rem;}
    .sidebar-user-name{font-size:0.82rem;font-weight:600;color:#e2e8f0;} .sidebar-user-role{font-size:0.72rem;color:var(--text-muted-custom);}
    .text-danger-soft{color:#f87171!important;} .text-danger-soft:hover{color:var(--danger)!important;background:var(--danger-soft)!important;}
    .main-content{margin-left:var(--sidebar-width);padding-top:var(--navbar-height);min-height:100vh;}
    .content-wrapper{padding:2rem;}
    .page-header{margin-bottom:2rem;} .page-title{font-size:1.6rem;font-weight:700;margin:0;} .page-subtitle{color:var(--text-muted-custom);font-size:0.875rem;margin-top:4px;}
    .app-footer{margin-left:var(--sidebar-width);border-top:1px solid var(--border-color);padding:1rem 2rem;}
    .footer-inner{display:flex;justify-content:space-between;align-items:center;}
    .footer-copy,.footer-version{font-size:0.8rem;color:var(--text-muted-custom);}
    .stat-card{background:var(--bg-card);border:1px solid var(--border-color);border-radius:16px;padding:1.5rem;transition:all 0.25s;position:relative;overflow:hidden;}
    .stat-card:hover{transform:translateY(-2px);border-color:rgba(99,102,241,0.3);}
    .stat-icon{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:1rem;}
    .stat-value{font-size:2rem;font-weight:700;line-height:1;margin-bottom:4px;} .stat-label{font-size:0.82rem;color:var(--text-muted-custom);font-weight:500;} .stat-change{font-size:0.78rem;margin-top:8px;}
    .table-card{background:var(--bg-card);border:1px solid var(--border-color);border-radius:16px;overflow:hidden;}
    .table-card-header{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border-color);display:flex;align-items:center;justify-content:space-between;}
    .table-card-title{font-size:1rem;font-weight:600;margin:0;}
    .table>:not(caption)>*>*{border-color:var(--border-color);}
    .table thead th{font-size:0.75rem;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--text-muted-custom);background:rgba(255,255,255,0.03);padding:0.85rem 1rem;}
    .table tbody td{padding:0.85rem 1rem;vertical-align:middle;font-size:0.875rem;}
    .table tbody tr:hover{background:rgba(255,255,255,0.03);}
    .status-badge-verified{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;background:var(--success-soft);color:var(--success);font-size:0.75rem;font-weight:600;}
    .status-badge-pending{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;background:var(--warning-soft);color:var(--warning);font-size:0.75rem;font-weight:600;}
    .status-badge-unverified{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;background:var(--danger-soft);color:var(--danger);font-size:0.75rem;font-weight:600;}
    .confidence-bar{height:4px;border-radius:2px;background:rgba(255,255,255,0.1);width:80px;display:inline-block;}
    .confidence-fill{height:100%;border-radius:2px;transition:width 0.3s;}
    .form-control,.form-select{background:var(--bg-surface);border-color:var(--border-color);color:#e2e8f0;border-radius:10px;}
    .form-control:focus,.form-select:focus{background:var(--bg-surface);border-color:var(--primary);color:#e2e8f0;box-shadow:0 0 0 3px var(--primary-soft);}
    .form-control::placeholder{color:var(--text-muted-custom);} .input-group-text{background:var(--bg-surface);border-color:var(--border-color);color:var(--text-muted-custom);}
    .btn-primary{background:linear-gradient(135deg,var(--primary),#8b5cf6);border:none;border-radius:10px;font-weight:600;transition:all 0.2s;}
    .btn-primary:hover{transform:translateY(-1px);box-shadow:0 4px 15px rgba(99,102,241,0.4);}
    .btn-success{background:var(--success);border-color:var(--success);border-radius:10px;} .btn-danger{border-radius:10px;} .btn-warning{border-radius:10px;}
    .btn-outline-secondary{border-color:var(--border-color);color:#9ca3af;border-radius:10px;} .btn-outline-secondary:hover{background:var(--bg-card);color:white;}
    .btn-sm{font-size:0.78rem;padding:4px 10px;}
    .pagination .page-link{background:var(--bg-card);border-color:var(--border-color);color:#9ca3af;border-radius:8px!important;}
    .pagination .page-link:hover{background:var(--primary-soft);color:white;} .pagination .active .page-link{background:var(--primary);border-color:var(--primary);color:white;}
    .dropdown-menu{background:var(--bg-card);border-color:var(--border-color);border-radius:14px;}
    .dropdown-item{color:#c4c9df;border-radius:8px;margin:2px 4px;} .dropdown-item:hover{background:var(--primary-soft);color:white;} .dropdown-divider{border-color:var(--border-color);}
    .chart-container{position:relative;height:240px;}
    .img-thumbnail-sm{width:48px;height:48px;object-fit:cover;border-radius:10px;border:1px solid var(--border-color);cursor:pointer;transition:transform 0.2s;}
    .img-thumbnail-sm:hover{transform:scale(1.1);}
    .timeline{list-style:none;padding:0;margin:0;} .timeline-item{position:relative;padding:0 0 1.5rem 2rem;}
    .timeline-item::before{content:'';position:absolute;left:7px;top:22px;width:2px;bottom:0;background:var(--border-color);}
    .timeline-item:last-child::before{display:none;}
    .timeline-dot{position:absolute;left:0;top:4px;width:16px;height:16px;border-radius:50%;background:var(--primary);border:2px solid var(--bg-base);}
    .timeline-action{font-size:0.82rem;font-weight:600;} .timeline-meta{font-size:0.75rem;color:var(--text-muted-custom);}
    .toast-container{z-index:9999;}
    .toast{background:var(--bg-card);border:1px solid var(--border-color);border-radius:14px;}
    @media(max-width:768px){.sidebar{transform:translateX(-100%);}.sidebar.show{transform:translateX(0);}.main-content,.app-footer{margin-left:0;}}
  </style>
</head>
<body>
<%- include('./partials/navbar') %>
<div class="d-flex">
  <%- include('./partials/sidebar') %>
  <div class="main-content w-100">
    <div class="content-wrapper">
